{
  "name": "sveltekit",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "prepare": "svelte-kit sync",
    "preview": "vite preview",
    "fmt": "prettier . --experimental-cli --cache-location .prettiercache --check",
    "fmt:fix": "prettier . --experimental-cli --cache-location .prettiercache --write",
    "lint": "pnpm run --workspace-root --parallel /lint:/",
    "lint:eslint": "eslint --cache --concurrency auto",
    "lint:svelte": "svelte-check --fail-on-warnings"
  },
  "dependencies": {
    "@sveltejs/kit": "^2.65.0",
    "svelte": "^5.56.3"
  },
  "devDependencies": {
    "@bastidood/eslint-plugin-imsort": "^0.12.0",
    "@eslint/css": "^1.3.0",
    "@eslint/js": "^10.0.1",
    "@html-eslint/eslint-plugin": "^0.62.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.3",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^16.5.0",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte-check": "^4.6.0",
    "tailwind-csstree": "^0.3.3",
    "tailwindcss": "^4.3.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16"
  }
}
