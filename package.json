{
  "name": "sveltekit",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "prepare": "svelte-kit sync",
    "preview": "vite preview",
    "fmt": "prettier . --experimental-cli --cache-location .prettiercache --check",
    "fmt:fix": "prettier . --experimental-cli --cache-location .prettiercache --write",
    "lint": "pnpm run --workspace-root --parallel /lint:/",
    "lint:eslint": "eslint --cache --concurrency auto",
    "lint:svelte": "svelte-check"
  },
  "dependencies": {
    "@sveltejs/kit": "^2.61.0",
    "svelte": "^5.55.9"
  },
  "devDependencies": {
