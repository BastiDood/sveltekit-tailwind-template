{
  "name": "sveltekit",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "prepare": "svelte-kit sync",
    "preview": "vite preview",
    "fmt": "prettier . --experimental-cli --cache-location .prettiercache --check",
    "fmt:fix": "prettier . --experimental-cli --cache-location .prettiercache --write",
    "lint": "pnpm run --workspace-root --parallel /lint:/",
    "lint:eslint": "eslint --cache --concurrency auto",
    "lint:svelte": "svelte-check --fail-on-warnings"
  },
  "dependencies": {
    "@sveltejs/kit": "^2.61.1",
    "svelte": "^5.56.1"
  },
  "devDependencies": {
